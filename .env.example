# Used by docker-compose to provision the MySQL container
MYSQL_DATABASE=rust_axum_sqlx
MYSQL_USER=notes
MYSQL_PASSWORD=notes_pw
MYSQL_ROOT_PASSWORD=root_pw

# Used by the Rust app (and sqlx-cli if you run migrations locally).
# Note: dotenvy does NOT expand ${VAR} references — write the literal URL.
DATABASE_URL=mysql://notes:notes_pw@127.0.0.1:3307/rust_axum_sqlx

# Optional
# RUST_LOG=info,tower_http=info,sqlx=warn
# BIND_ADDR=0.0.0.0:8080
# DB_MAX_CONNECTIONS=10
